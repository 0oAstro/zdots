#!/bin/zsh
#
# .zstyles — zstyle settings for completion, history, plugins, antidote
#

# ── antidote ─────────────────────────────────────────────────────
zstyle ':antidote:home'  path "$ANTIDOTE_HOME"
zstyle ':antidote:repo'  path "$ZDOTDIR/.antidote"
zstyle ':antidote:*'     zcompile 'yes'

# ── ez-compinit ──────────────────────────────────────────────────
zstyle ':plugin:ez-compinit' 'compstyle' 'zshzoo'
# Disable compinit -C (unsafe). Without this, completions for newly
# installed tools may not appear without manually deleting the dump.
zstyle ':plugin:ez-compinit' 'use-cache' no
